<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_rahatone" model="ir.ui.view">
        <field name="name">res.users.form.rahatone</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="RAHAT-ONE">
                    <group>
                        <group>
                            <field name="rahatone_role"/>
                            <field name="employee_id"/>
                            <field name="is_rahatone_user"/>
                        </group>
                        <group>
                            <field name="account_status"/>
                            <field name="last_login_date"/>
                            <field name="failed_login_attempts"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
